# ==========================================
# Multi-Tenant SaaS Audit Log System
# Environment Configuration Template
# ==========================================

# Gateway API Port
PORT=8080

# Kafka Broker Connections
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_INTERNAL_SERVER=kafka:9093

# MinIO Connection Details
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Archival Configuration (in milliseconds)
ARCHIVE_INTERVAL_MS=300000

# Tenant Credentials
TENANT_ACME_PASSWORD=tenant-acme-password
TENANT_GLOBEX_PASSWORD=tenant-globex-password
TENANT_INITECH_PASSWORD=tenant-initech-password

# Service credentials used by the gateway and archiver
SYSTEM_USER=gateway-system
SYSTEM_PASSWORD=gateway-system-password
ADMIN_USER=admin
ADMIN_PASSWORD=admin-password

# Test helpers
TEST_TENANT_USER=tenant-globex
TEST_TENANT_PASS=tenant-globex-password
